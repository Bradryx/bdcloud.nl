---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog · Brandon van Dijk"
  description="Technical posts on Microsoft Modern Workplace, Endpoint Management, Azure, and Information Protection."
  canonicalUrl="https://bdcloud.nl/blog/"
>
  <section class="blog-header">
    <div class="section-label">// Blog</div>
    <h1>Writing</h1>
    <p class="blog-sub">Technical posts on Microsoft Modern Workplace, endpoint management, Azure, and information protection.</p>
  </section>

  <section class="posts">
    {posts.length === 0 ? (
      <div class="empty">
        <span class="empty-icon">// </span>No posts yet. Check back soon.
      </div>
    ) : (
      posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-item">
          <div class="post-meta">
            <span class="post-date">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
            {post.data.tags && post.data.tags.map(tag => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
          <div class="post-title">{post.data.title}</div>
          <div class="post-desc">{post.data.description}</div>
          <span class="post-arrow">→</span>
        </a>
      ))
    )}
  </section>
</Layout>

<style>
  .blog-header { padding: 5rem 0 3rem; }
  .section-label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); letter-spacing: 0.08em; margin-bottom: 0.75rem; }
  h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 1.5rem; }
  .blog-sub { font-size: 1rem; color: var(--fg-muted); max-width: 480px; line-height: 1.7; }
  .posts { display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 2rem; }
  .post-item { display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto auto auto; padding: 1.5rem 1.75rem; background: var(--bg-card); border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; transition: background 0.2s, transform 0.2s; gap: 0.4rem 1rem; }
  .post-item:last-child { border-bottom: none; }
  .post-item:hover { background: var(--bg-card-hover); transform: translateX(3px); }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; grid-column: 1; grid-row: 1; }
  .post-date { font-family: var(--font-mono); font-size: 0.75rem; color: var(--fg-muted); }
  .post-tag { font-family: var(--font-mono); font-size: 0.65rem; background: var(--accent-dim); color: var(--accent); padding: 0.15rem 0.5rem; border-radius: 3px; }
  .post-title { font-size: 1.05rem; font-weight: 700; letter-spacing: -0.02em; grid-column: 1; grid-row: 2; }
  .post-desc { font-size: 0.88rem; color: var(--fg-muted); line-height: 1.6; grid-column: 1; grid-row: 3; }
  .post-arrow { font-size: 1.2rem; color: var(--accent); grid-column: 2; grid-row: 1 / 4; align-self: center; }
  .empty { padding: 3rem 1.75rem; background: var(--bg-card); font-family: var(--font-mono); font-size: 0.9rem; color: var(--fg-muted); }
  .empty-icon { color: var(--accent); }
  @media (max-width: 600px) {
    .post-item { grid-template-columns: 1fr; }
    .post-arrow { display: none; }
  }
</style>
