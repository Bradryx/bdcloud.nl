    font-weight: 600;
    grid-column: 1;
    grid-row: 2;
    letter-spacing: -0.01em;
  }

  .cert-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-muted);
    grid-column: 2;
    grid-row: 1 / 3;
    text-align: right;
  }

  /* ── CONTACT ── */
  .contact-sub {
    color: var(--fg-muted);
    margin-bottom: 2.5rem;
    max-width: 420px;
    font-size: 1rem;
  }

  .contact-links {
