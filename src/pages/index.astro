<script>
  // ── SCROLL ANIMATIONS ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  // Observe section titles and labels
  document.querySelectorAll('.section-title, .section-label').forEach(el => {
    el.classList.add('scroll-fade');
    observer.observe(el);
  });

  // Observe cards with stagger
  document.querySelectorAll('.card').forEach((el, i) => {
    el.classList.add('scroll-fade');
    el.style.transitionDelay = `${i * 80}ms`;
    observer.observe(el);
  });

  // Observe cert items with stagger
  document.querySelectorAll('.cert-item').forEach((el, i) => {
    el.classList.add('scroll-fade-left');
    el.style.transitionDelay = `${i * 60}ms`;
    observer.observe(el);
  });

  // Observe contact items with stagger
  document.querySelectorAll('.contact-item').forEach((el, i) => {
    el.classList.add('scroll-fade');
    el.style.transitionDelay = `${i * 80}ms`;
    observer.observe(el);
  });

  // Observe contact subtitle
  document.querySelectorAll('.contact-sub').forEach(el => {
    el.classList.add('scroll-fade');
    observer.observe(el);
  });
</script>

<style is:global>
  /* ── TOKENS ── */
  :root {
    --bg: #f5f4f0;
    --bg-card: #eeecea;
    --bg-card-hover: #e6e4df;
    --fg: #111110;
    --fg-muted: #5a5955;
    --accent: #0066ff;
    --accent-dim: #d0e0ff;
    --border: rgba(0,0,0,0.08);
    --expert: #0050cc;
    --associate: #1a7a4a;
    --fundamentals: #7a5c00;
    --expert-bg: #dce8ff;
    --associate-bg: #d4f0e4;
    --fundamentals-bg: #fef0c0;
    --font-display: 'Syne', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0e0e0d;
      --bg-card: #161614;
      --bg-card-hover: #1e1e1b;
      --fg: #f0ede8;
      --fg-muted: #888680;
      --accent: #4d8fff;
      --accent-dim: #0a1a33;
      --border: rgba(255,255,255,0.07);
      --expert: #6699ff;
      --associate: #4dbb7a;
      --fundamentals: #e6b800;
      --expert-bg: #0d1e3d;
      --associate-bg: #0d2b1a;
      --fundamentals-bg: #2a2000;
    }
  }

  /* ── RESET ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-display);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── TEXTURE & GRID ── */
  .noise {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  .grid-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* ── LAYOUT ── */
  main {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── NAV ── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg-muted);
  }

  .nav-logo .accent { color: var(--accent); }

  .cursor {
    color: var(--accent);
    animation: blink 1.2s step-end infinite;
    margin-left: 1px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--accent); }

  /* ── HERO ── */
  .hero {
    padding: 7rem 0 6rem;
    position: relative;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
  }

  .hero-photo-wrap {
    position: relative;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .hero-photo {
    width: 220px;
    height: 220px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border);
    display: block;
    filter: grayscale(20%);
    transition: filter 0.3s;
  }

  .hero-photo:hover { filter: grayscale(0%); }

  .hero-current {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-muted);
    gap: 0.15rem;
  }

  .current-label {
    color: var(--accent);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.1s;
  }

  h1 {
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.2s;
  }

  .name-outline {
    -webkit-text-stroke: 2px var(--fg);
    color: transparent;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--fg-muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.35s;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.5s;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

  .btn-ghost {
    color: var(--fg-muted);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    transition: color 0.2s;
  }

  .btn-ghost:hover { color: var(--fg); }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.7s;
    white-space: nowrap;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px #22c55e;
    animation: pulse 2s infinite;
  }

  /* ── SECTIONS ── */
  .section {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
    line-height: 1.1;
  }

  /* ── CARDS ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .card {
    background: var(--bg-card);
    padding: 2rem;
    transition: background 0.2s;
    position: relative;
  }

  .card:hover { background: var(--bg-card-hover); }

  .card-icon {
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 1rem;
    display: block;
  }

  .card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .card p {
    font-size: 0.88rem;
    color: var(--fg-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-tags span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--accent-dim);
    color: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  /* ── CERTS ── */
  .cert-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .cert-item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    align-items: center;
    padding: 1.25rem 1.75rem;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s, transform 0.2s;
    gap: 0.25rem 1rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .cert-item:last-child { border-bottom: none; }
  .cert-item:hover { background: var(--bg-card-hover); transform: translateX(3px); }

  .cert-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    grid-column: 1;
    grid-row: 1;
  }

  .cert-code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.05em;
  }

