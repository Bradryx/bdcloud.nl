    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--fg);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
